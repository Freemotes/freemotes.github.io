---
layout: layout.njk
title: "Emotes"
date: 2010-03-10
---

<div class="filters" style="margin-bottom: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
  <button class="filter-btn active" data-filter="all">All</button>
  <button class="filter-btn" data-filter="static">Static</button>
  <button class="filter-btn" data-filter="animated">Animated</button>
</div>

<div class="grid" id="emoteGrid">
  {% set sortedEmotes = collections.emotes | reverse %}
  {% set shownVariationGroups = [] %}

  {% for emote in sortedEmotes %}
    {% if emote.inputPath != "./src/emotes/index.md" %}
      {% set tags = emote.data.tags or [] %}

      {% if emote.data.variation_group %}
        {% if emote.data.variation_group not in shownVariationGroups %}
          {% set shownVariationGroups = shownVariationGroups.concat([emote.data.variation_group]) %}

          <a
            class="card variation-card"
            href="/emotes/variations/{{ emote.data.variation_group }}/"
            data-tags="{{ tags | join(' ') | lower }}"
            title="This emote has alternative color variations available"
          >
            <img
              loading="lazy"
              src="{{ emote.data.variation_icon or emote.data.image }}"
              alt="{{ emote.data.variation_group }} variations"
            >
            <span class="variation-badge">🎨</span>
          </a>
        {% endif %}

      {% else %}
        <a
          class="card"
          href="{{ emote.url }}"
          data-tags="{{ tags | join(' ') | lower }}"
        >
          <img loading="lazy" src="{{ emote.data.image }}" alt="{{ emote.data.title }}">
        </a>
      {% endif %}

    {% endif %}
  {% endfor %}
</div>

<style>
  .filter-btn {
    background: #18181b;
  }

  .filter-btn.active {
    background: #9146ff;
  }
</style>

<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll("#emoteGrid .card");

  buttons.forEach(button => {
    button.addEventListener("click", () => {
      const selected = button.dataset.filter;

      // Toggle active button
      buttons.forEach(btn => btn.classList.remove("active"));
      button.classList.add("active");

      // Filter cards
      cards.forEach(card => {
        const tags = (card.dataset.tags || "").toLowerCase();

        if (selected === "all") {
          card.style.display = "";
        } else {
          card.style.display = tags.includes(selected) ? "" : "none";
        }
      });
    });
  });
</script>