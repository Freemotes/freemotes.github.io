<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
  {% if title %}
    {% if title.includes("Freemotes") %}
      {{ title }}
    {% else %}
      Freemotes - {{ title }}
    {% endif %}
  {% else %}
    Freemotes
  {% endif %}
</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

<div class="wrapper">
  <header>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/emotes/">Emotes</a></li>
        <li><a href="/about">About Me</a></li>
      </ul>
    </nav>
  </header>


  <main class="page-body">
    <h1>{{ title }}</h1>

    {% if image %}
      <img src="{{ image }}" alt="{{ title }}" width="112" height="112">
    {% endif %}

      {% if image_56 %}
      <img src="{{ image_56 }}" alt="{{ title }}">
    {% endif %}

      {% if image_28 %}
      <img src="{{ image_28 }}" alt="{{ title }}">
    {% endif %}

    {% if description %}
      <p>{{ description }}</p>
    {% endif %}

    {{ content | safe }}

    {% if image_56 or image_28 %}
  <p>
    When uploading this emote to Twitch, please disable the "Auto-resize" slider,
    and instead upload the 3 images to their respective dimension slots.
  </p>
  {% endif %}

  <h3>Search for an emote:</h3>

  <div style="position: relative; max-width: 300px; display: flex; gap: 6px;">
    <input 
      type="text" 
      id="searchInput" 
      placeholder="Search emotes..." 
      autocomplete="off" 
    />
    <button id="searchButton">Search</button>

    <ul id="suggestions" style="
      border-radius: 6px;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      list-style: none;
      padding: 0;
      margin: 4px 0 0;
      background: #18181b;
      max-height: 150px;
      overflow-y: auto;
    "></ul>
    
  </div>

  <script>
  const input = document.getElementById("searchInput");
  const button = document.getElementById("searchButton");
  const suggestionsBox = document.getElementById("suggestions");
  const searchWrap = document.getElementById("searchWrap");

  let allTags = [];

  // Load tags from search.json
  fetch("/search.json")
    .then(res => res.json())
    .then(data => {
      const tagSet = new Set();

      data.forEach(item => {
        if (Array.isArray(item.tags)) {
          item.tags.forEach(tag => {
            const clean = String(tag).trim().toLowerCase();
            if (clean) tagSet.add(clean);
          });
        }
      });

      allTags = Array.from(tagSet).sort();
    })
    .catch(err => {
      console.error("Failed to load tags:", err);
    });

  function performSearch() {
    const query = input.value.trim();
    if (query) {
      window.location.href = `/search/?q=${encodeURIComponent(query)}`;
    }
  }

  function clearSuggestions() {
    suggestionsBox.innerHTML = "";
    suggestionsBox.style.display = "none";
  }

  function showSuggestions(matches) {
    suggestionsBox.innerHTML = "";

    if (!matches.length) {
      suggestionsBox.style.display = "none";
      return;
    }

    matches.forEach(tag => {
      const li = document.createElement("li");
      li.textContent = tag;
      li.style.padding = "6px";
      li.style.cursor = "pointer";

      li.addEventListener("mouseenter", () => {
        li.style.background = "#27272a";
      });

      li.addEventListener("mouseleave", () => {
        li.style.background = "transparent";
      });

      li.addEventListener("click", () => {
        input.value = tag;
        clearSuggestions();
        input.focus();
      });

      suggestionsBox.appendChild(li);
    });

    suggestionsBox.style.display = "block";
  }

  // Button click
  button.addEventListener("click", performSearch);

  // Enter key
  input.addEventListener("keydown", function (event) {
    if (event.key === "Enter") {
      performSearch();
    }
  });

  // Autocomplete logic (TAGS ONLY)
  input.addEventListener("input", function () {
    const query = input.value.trim().toLowerCase();

    if (!query) {
      clearSuggestions();
      return;
    }

    const startsWith = [];
    const contains = [];

    for (const tag of allTags) {
      if (tag.startsWith(query)) {
        startsWith.push(tag);
      } else if (tag.includes(query)) {
        contains.push(tag);
      }

      if (startsWith.length + contains.length >= 5) break;
    }

    showSuggestions([...startsWith, ...contains].slice(0, 5));
  });

  // Hide suggestions when clicking outside
  document.addEventListener("click", (e) => {
    if (!searchWrap.contains(e.target)) {
      clearSuggestions();
    }
  });
</script>
  </main>

  <footer class="page-footer">
    <p>
      Emotes created by <a href="https://www.twitch.tv/gromfalloon" target="_blank" rel="noopener noreferrer">Gromfalloon</a> on Twitch, please <a href="/attribute">attribute</a> the emotes when you upload them. 
    </p>
  </footer>
  </div>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<script>
async function downloadEmote() {
  // Build array safely (ignore empty strings)
  const images = [];

  if ("{{ image }}") images.push("{{ image }}");
  if ("{{ image_56 }}" && "{{ image_56 }}" !== "") images.push("{{ image_56 }}");
  if ("{{ image_28 }}" && "{{ image_28 }}" !== "") images.push("{{ image_28 }}");

  // ✅ Debug (optional, helps confirm)
  console.log("Images found:", images);

  if (images.length === 1) {
    const a = document.createElement("a");
    a.href = images[0];
    a.download = images[0].split("/").pop();
    a.click();
    return;
  }

  // Multiple images → ZIP
  const zip = new JSZip();

  for (const img of images) {
    const res = await fetch(img);
    const blob = await res.blob();
    const filename = img.split("/").pop();
    zip.file(filename, blob);
  }

  const zipBlob = await zip.generateAsync({ type: "blob" });

  const a = document.createElement("a");
  a.href = URL.createObjectURL(zipBlob);

  const safeName = "{{ title | safe }}".toLowerCase().replace(/[^a-z0-9]+/g, "-");
  a.download = safeName + ".zip";

  a.click();
}
</script>